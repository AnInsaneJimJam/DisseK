# Fileverse API server URL (same URL used by the MCP server)
FILEVERSE_API_URL=http://localhost:3000

# Backend port (default: 3001)
PORT=3001

# x402 Payment Configuration
# Your EVM wallet address to receive payments
EVM_PAY_TO_ADDRESS=0xYourWalletAddress
# x402 facilitator URL (public default)
X402_FACILITATOR_URL=https://x402.org/facilitator
# CAIP-2 network ID (eip155:84532 = Base Sepolia, eip155:8453 = Base Mainnet)
X402_NETWORK=eip155:84532
# Price for a single disclosure request (USDC)
DISCLOSURE_PRICE=$0.01

# Ethereum RPC URLs for ENS resolution (ENSIP-25)
# Leave blank to use default public RPCs (rate-limited)
# Recommended: use Alchemy, Infura, or any reliable RPC
ETH_RPC_URL=
SEPOLIA_RPC_URL=
BASE_SEPOLIA_RPC_URL=
