# Fileverse API server URL (same URL used by the MCP server)
FILEVERSE_API_URL=http://localhost:3000

# Backend port (default: 3001)
PORT=3001

# Ethereum RPC URLs for ENS resolution (ENSIP-25)
# Leave blank to use default public RPCs (rate-limited)
# Recommended: use Alchemy, Infura, or any reliable RPC
ETH_RPC_URL=
SEPOLIA_RPC_URL=
BASE_SEPOLIA_RPC_URL=
