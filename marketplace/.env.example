# Marketplace port (default: 3002)
MARKETPLACE_PORT=3002

# x402 Payment Configuration
# Your EVM wallet address to receive payments
EVM_PAY_TO_ADDRESS=0xYourWalletAddress
# x402 facilitator URL (public default)
X402_FACILITATOR_URL=https://x402.org/facilitator
# CAIP-2 network ID (eip155:84532 = Base Sepolia, eip155:8453 = Base Mainnet)
X402_NETWORK=eip155:84532
# Price for a single purchase request (USDC)
PURCHASE_PRICE=$0.01

# Firebase (optional — falls back to in-memory if not set)
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json
